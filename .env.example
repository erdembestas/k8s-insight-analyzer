# Example environment variables for LLM and runtime
# Copy this to .env and populate

# LLM (if using single-provider mode)
LLM_API_URL=https://api.example-llm.com/v1
LLM_API_TOKEN=replace_with_token
LLM_MODEL=gpt-4.1-mini

# Behavior
MOCK_LLM=1 # set to 1 for local dry-run simulations
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0

# Artifacts directory override (optional)
ARTIFACTS_DIR=./artifacts
